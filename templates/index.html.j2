<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tech News Digest</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      color-scheme: light dark;
      --bg: #0b0c10;
      --card: #1f2833;
      --text: #c5c6c7;
      --accent: #66fcf1;
    }
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      font-family: 'Space Grotesk', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    header {
      padding: 2rem 1.5rem 1rem;
      text-align: center;
    }
    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3rem);
      letter-spacing: -0.02em;
    }
    .meta {
      color: #888;
      font-size: 0.9rem;
      margin-top: 0.5rem;
    }
    main {
      max-width: 1200px;
      margin: 0 auto 3rem;
      padding: 0 1.5rem 2rem;
      display: grid;
      gap: 1.5rem;
    }
    section {
      background: var(--card);
      border-radius: 16px;
      padding: 1.25rem;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    section h2 {
      margin-top: 0;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 1.35rem;
    }
    section h2 a {
      color: var(--accent);
      text-decoration: none;
      font-size: 0.9rem;
    }
    ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    li a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      font-size: 1.05rem;
    }
    li p {
      margin: 0.35rem 0 0;
      line-height: 1.5;
      color: #a8b2bf;
    }
    li .timestamp {
      font-size: 0.85rem;
      color: #778;
    }
    footer {
      text-align: center;
      padding: 2rem;
      color: #777;
      font-size: 0.9rem;
    }
    @media (min-width: 900px) {
      main {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Tech News Digest</h1>
    <div class="meta">Updated {{ generated_at }} UTC · <a href="feeds.json" style="color: var(--accent);">JSON feed</a></div>
  </header>
  <main>
    {% for feed in feeds %}
    <section>
      <h2>
        {{ feed.name }}
        <a href="{{ feed.url }}" target="_blank" rel="noopener">Source ↗</a>
      </h2>
      {% if feed.error %}
      <p style="color: #f36;">Error fetching feed: {{ feed.error }}</p>
      {% endif %}
      <ul>
        {% for item in feed.entries %}
        <li>
          <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
        
          {% if item.published %}
          <div class="timestamp">{{ item.published }}</div>
          {% endif %}
          {% if item.summary %}
          <p>{{ item.summary }}</p>
          {% endif %}
        </li>
        {% endfor %}
        {% if not feed.entries %}
        <li>No recent items.</li>
        {% endif %}
      </ul>
    </section>
    {% endfor %}
  </main>
  <footer>
    Powered by Python · GitHub Pages · <a href="https://github.com/buckwild/tech-news-digest" style="color: var(--accent);">Source</a>
  </footer>
</body>
</html>
